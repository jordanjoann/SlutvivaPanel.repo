# ─────────────────────────────────────────────────────────────
# Slutvival Panel — environment configuration
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# The panel never exposes these values to the browser.
# ─────────────────────────────────────────────────────────────

# ── Panel authentication ──────────────────────────────────────
# Local account data is stored at /opt/slutvival/data/panel-auth.json by default.
# Default setup credentials are Admin / 9876 until changed in Account.
SLUTVIVAL_AUTH_SECRET=
SLUTVIVAL_AUTH_FILE=

# ── Discord integration ───────────────────────────────────────
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# ── Cloudflare (DNS / tunnels) ────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── GitHub (updates / releases) ───────────────────────────────
GITHUB_TOKEN=

# ── Vintage Story account (game file downloads) ───────────────
VINTAGE_STORY_ACCOUNT_EMAIL=
VINTAGE_STORY_ACCOUNT_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Infrastructure paths & runtime (optional — sensible defaults)
# ─────────────────────────────────────────────────────────────

# Root of the Slutvival infra. Defaults to /opt/slutvival on Linux,
# or ./.slutvival-data on Windows dev boxes.
# SLUTVIVAL_ROOT=/opt/slutvival

# Docker
# DOCKER_SOCKET=/var/run/docker.sock
# SLUTVIVAL_DOCKER_NETWORK=slutvival-net
# VINTAGE_STORY_IMAGE=slutvival/vintage-story:latest

# Panel domain
# PANEL_DOMAIN=panel.slutvival.com

# Runtime selection: auto | docker | process | simulated
# `auto` prefers docker, then a local dotnet process, then a built-in
# simulator so the UI is fully interactive even without a real server.
# PANEL_RUNTIME=auto

B2_GAME_BACKUPS_BUCKET=
B2_SYSTEM_BACKUPS_BUCKET=
B2_S3_ENDPOINT=
B2_REGION=
B2_GAME_BACKUPS_KEY_ID=
B2_GAME_BACKUPS_APPLICATION_KEY=
B2_SYSTEM_BACKUPS_KEY_ID=
B2_SYSTEM_BACKUPS_APPLICATION_KEY=
SLUTVIVAL_BACKUP_STAGING_DIR=/opt/slutvival/backups/staging
SLUTVIVAL_PANEL_DB=/opt/slutvival/data/slutvival-panel.sqlite
SLUTVIVAL_SYSTEM_BACKUP_AGE_RECIPIENT=
